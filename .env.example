PORT=5000
MONGO_URI=

# SMTP (password reset emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# Deep link target for reset password email (mobile app route)
# Example: foodalleryscanner://reset-password
RESET_PASSWORD_URL=foodalleryscanner://reset-password

# OCR
OCR_PROVIDER=google-vision
GOOGLE_VISION_API_KEY=
OCR_FALLBACK_TO_TESSERACT=true

# AI analysis
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# JWT (required for login and protected APIs — use a random string ≥32 chars)
JWT_SECRET=
JWT_EXPIRES_IN=7d
ADMIN_JWT_EXPIRES_IN=12h
